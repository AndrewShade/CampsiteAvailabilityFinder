# Get a free key at https://ridb.recreation.gov/apikeys
RIDB_API_KEY=your_ridb_api_key_here

# How often to poll Recreation.gov for availability (minutes)
CHECK_INTERVAL_MINUTES=15

# Set to true for verbose FastAPI logs
DEBUG=false

# Comma-separated list of allowed CORS origins
# Add your Proxmox server's IP/hostname here
ALLOWED_ORIGINS=["http://localhost:3000","http://your-proxmox-ip:3000"]
