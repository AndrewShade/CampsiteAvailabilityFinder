# Get a free key at https://ridb.recreation.gov/apikeys
RIDB_API_KEY=your_key_here

# Your Discord webhook URL (Settings > Integrations > Webhooks in any Discord channel)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook

# How often to poll Recreation.gov for availability (minutes)
CHECK_INTERVAL_MINUTES=15
